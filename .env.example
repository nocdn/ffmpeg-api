# Server port
PORT=8040

# Max upload file size in megabytes
MAX_FILE_SIZE_MB=2048

# Max requests per minute for /api/process (global across all clients)
RATE_LIMIT_PER_MINUTE=1

# Max requests per minute for /api/health
HEALTH_RATE_LIMIT_PER_MINUTE=60

# Kill ffmpeg if it runs longer than this (seconds)
PROCESS_TIMEOUT_SECONDS=360
